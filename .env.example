# AgentCheck — Environment Variables
# Copy this to .env and fill in your values

# Required: Your agent wallet private key (with 0x prefix)
ACP_PRIVATE_KEY=0x...

# Required: Your agent wallet address (with 0x prefix)
ACP_AGENT_WALLET=0x...

# Required: Session entity key ID (get this when you register your agent on Virtuals)
ACP_SESSION_KEY_ID=0

# Optional: Custom Base RPC URL (recommended to avoid rate limits)
# Get a free one from Alchemy, Infura, or QuickNode
ACP_RPC_URL=
